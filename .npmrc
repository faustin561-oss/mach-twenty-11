# @stripe/react-stripe-js's peer dependency on react (^16.8.0 || ^17.0.0 ||
# ^18.0.0) has not been updated for React 19 as of this writing — this is
# a real, currently-open upstream gap (stripe/react-stripe-js#540 on
# GitHub), not a version mismatch on this project's side. The library's
# actual code (standard React hooks) works fine with React 19 in
# practice; only the peerDependencies field in its own package.json
# hasn't caught up yet.
#
# legacy-peer-deps here (not --force, and not a CLI flag you have to
# remember to pass) is npm's own documented response to exactly this
# situation. It's a project-level config file, so both `npm install`
# (what Vercel runs) and `npm ci` (what the Dockerfile runs) pick it up
# automatically without needing separate configuration per platform.
legacy-peer-deps=true
