# This file documents every environment variable this project uses.
#
# For local preview (npm install --legacy-peer-deps && npm run dev), you
# do NOT need to create a .env file or set anything here — the app has
# safe, clearly-labeled fallbacks for local development (see
# src/lib/auth.ts and src/lib/safe-db.ts / src/lib/api-error.ts). Copy
# this file to .env only once you want real data (a real database) or are
# preparing an actual deployment.

# Database — fully optional for local preview now. If you don't set this
# at all, the app defaults to a local SQLite file (prisma/dev.db, created
# automatically) — no Postgres, no Docker, no external database server
# needed to test the platform. This is what makes plain
# `npm install --legacy-peer-deps && npm run dev` work with zero setup.
#
# Uncomment the line below only if you want to point at a real SQLite
# file path explicitly (rarely necessary — the code default already
# does this):
# DATABASE_URL="file:./dev.db"
#
# For real production data: Postgres, via the separate
# prisma/schema.production.prisma file (Prisma can't switch datasource
# provider dynamically from one env var — see the comment atop that file
# for why two schema files, not one, is the actual mechanism). Set a real
# connection string here in production, e.g.:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
# Then use the *:production npm scripts (generate:production,
# db:push:production, db:migrate:production, build:production) — see
# DEPLOYMENT.md for a full walkthrough, including a concrete Railway setup.
# (docker-compose.yml includes a local Postgres service with matching
# credentials — postgresql://mach2011:mach2011@localhost:5432/mach2011 —
# handy for testing the production schema path locally before deploying.)

# Auth.js — optional for local dev (npm run dev falls back to a fixed,
# insecure, checked-into-source dev secret automatically — see
# src/lib/auth.ts). REQUIRED in production, with no fallback: `npm run
# build` will refuse to proceed without a real value here if NODE_ENV is
# actually set to "production" (see scripts/check-env.js).
#
# Generate a real value with ONE of:
#   macOS/Linux:   openssl rand -base64 32
#   Any platform:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Paste the output below, replacing the placeholder, before deploying.
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# Auth.js v5 recognizes both names; NEXTAUTH_URL is kept for backward
# compatibility with v4 tutorials, AUTH_URL is the current preferred name.
# Setting either is sufficient — you do not need both. Only required at
# all if AUTH_TRUST_HOST/trustHost inference doesn't already cover your
# setup (it's set to true below for exactly this reason); harmless to set
# regardless.
NEXTAUTH_URL="http://localhost:3000"
# AUTH_URL="http://localhost:3000"

# Required behind any reverse proxy / container / non-Vercel host (i.e.
# most real deployments) — without it Auth.js can separately reject
# requests with "Host must be trusted", even once AUTH_SECRET is set
# correctly. Already also set as `trustHost: true` in src/lib/auth.ts;
# the env var and the code option are redundant, not conflicting.
AUTH_TRUST_HOST="true"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Single carrier membership plan: $19.99/mo. Create this Price in the
# Stripe dashboard (Product: "Mach Twenty 11 Carrier Membership",
# recurring monthly, $19.99) and paste its Price ID (starts with
# "price_") here. There is no per-tier pricing anymore — one plan.
STRIPE_CARRIER_PRICE_ID=""

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Redis (Socket.IO adapter, caching, rate limiting)
REDIS_URL="redis://localhost:6379"

# Cron — required in the Authorization: Bearer header when calling
# /api/cron/reveal-bids from your scheduler.
CRON_SECRET="replace-with-openssl-rand-hex-32"

# AWS S3 (documents, photos)
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""

# Email / SMS
RESEND_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
