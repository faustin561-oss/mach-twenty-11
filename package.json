{
  "name": "mach-twenty-11",
  "version": "0.1.0",
  "private": true,
  "description": "Mach Twenty 11 — Supply. Demand. Execute. Multimodal freight marketplace.",
  "scripts": {
    "check-env": "node scripts/check-env.js",
    "postinstall": "node scripts/db-sync.js generate",
    "predev": "node scripts/check-env.js && node scripts/db-sync.js push",
    "prebuild": "node scripts/check-env.js && node scripts/db-sync.js push",
    "dev": "next dev",
    "build": "node scripts/db-sync.js generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "generate:production": "prisma generate --schema=prisma/schema.production.prisma",
    "db:push:production": "prisma db push --schema=prisma/schema.production.prisma",
    "db:migrate:production": "prisma migrate deploy --schema=prisma/schema.production.prisma",
    "build:production": "npm run generate:production && next build",
    "docker:up": "docker compose up --build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "@prisma/client": "^5.20.0",
    "prisma": "^5.20.0",
    "next-auth": "^5.0.0-beta.31",
    "@auth/prisma-adapter": "^2.9.0",
    "bcryptjs": "2.4.3",
    "stripe": "16.12.0",
    "@stripe/stripe-js": "4.7.0",
    "socket.io": "4.8.0",
    "socket.io-client": "4.8.0",
    "ioredis": "5.4.1",
    "@googlemaps/js-api-loader": "1.16.8",
    "zod": "3.23.8",
    "react-hook-form": "7.53.0",
    "@hookform/resolvers": "3.9.0",
    "date-fns": "4.1.0",
    "lucide-react": "0.446.0",
    "clsx": "2.1.1",
    "tailwind-merge": "2.5.3",
    "@aws-sdk/client-s3": "3.658.1",
    "@aws-sdk/s3-request-presigner": "3.658.1",
    "resend": "4.0.0",
    "twilio": "5.3.0"
  },
  "devDependencies": {
    "@types/node": "22.7.4",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/bcryptjs": "2.4.6",
    "@types/google.maps": "3.58.1",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.13",
    "tsx": "4.19.1",
    "eslint": "^9.9.0",
    "@eslint/eslintrc": "^3.1.0",
    "eslint-config-next": "16.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
